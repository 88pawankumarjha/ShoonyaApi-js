SHOONYA_CLIENT_ID=
SHOONYA_SECRET_CODE=
SHOONYA_AUTH_CODE=

# Optional. Only set this if Shoonya requires uid in GenAcsTok for your app.
SHOONYA_UID=

# Optional overrides.
SHOONYA_OAUTH_LOGIN_URL=https://trade.shoonya.com/OAuthlogin
SHOONYA_OAUTH_TOKEN_URL=https://trade.shoonya.com/NorenWClientAPI/GenAcsTok

# Optional mobile OAuth callback listener.
SHOONYA_OAUTH_LISTEN_HOST=0.0.0.0
SHOONYA_OAUTH_LISTEN_PORT=8787
SHOONYA_OAUTH_CALLBACK_PATH=/callback
SHOONYA_OAUTH_PUBLIC_BASE_URL=
SHOONYA_OAUTH_AUTO_CLOSE=true
